    "templating": {
      "list": [
        {
          "name": "time_period",
          "type": "custom",
          "current": {
            "selected": true,
            "text": "all",
            "value": "all"
          },
          "options": [
            {
              "selected": true,
              "text": "all",
              "value": "all"
            },
            {
              "selected": false,
              "text": "1year",
              "value": "1year"
            },
            {
              "selected": false,
              "text": "2years",
              "value": "2years"
            },
            {
              "selected": false,
              "text": "5years",
              "value": "5years"
            }
          ],
          "query": "all,1year,2years,5years",
