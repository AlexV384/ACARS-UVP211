{
  "uid": "acars-coverage",
  "title": "ACARS Coverage Dashboard",
  "tags": ["acars", "coverage"],
  "timezone": "browser",
  "editable": false,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Всего рейсов",
      "type": "stat",
      "gridPos": {"h": 4, "w": 3, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS \"All Flights\" FROM flight_coverage;"
        }
      ]
    },
    {
      "id": 2,
      "title": "Авиакомпаний",
      "type": "stat",
      "gridPos": {"h": 4, "w": 3, "x": 3, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(DISTINCT airline_code) AS \"Airlines\" FROM airline_coverage WHERE time_period = 'all';"
        }
      ]
    },
    {
      "id": 3,
      "title": "Общее покрытие %",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 6, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(avg(avg_coverage_pct), 0) AS \"Overall Coverage %\" FROM airline_coverage WHERE time_period = 'all';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "green", "value": 70}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Активных рейсов (10 мин)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 3, "x": 10, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(DISTINCT callsign) AS \"Active Flights\" FROM tracks WHERE track_timestamp > now() - interval '10 min' AND callsign IS NOT NULL;"
        }
      ]
    },
    {
      "id": 12,
      "title": "Покрытие 1 год",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 13, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(avg(avg_coverage_pct), 0) AS \"Coverage 1 Year\" FROM airline_coverage WHERE time_period = '1year';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 13,
      "title": "Покрытие 2 года",
      "type": "stat",
      "gridPos": {"h": 4, "w": 3, "x": 17, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(avg(avg_coverage_pct), 0) AS \"Coverage 2 Years\" FROM airline_coverage WHERE time_period = '2years';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 14,
      "title": "Покрытие 5 лет",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(avg(avg_coverage_pct), 0) AS \"Coverage 5 Years\" FROM airline_coverage WHERE time_period = '5years';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 6,
      "title": "Покрытие по авиакомпаниям",
      "type": "barchart",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT airline_code AS metric, avg_coverage_pct FROM airline_coverage WHERE time_period = 'all' AND avg_coverage_pct IS NOT NULL ORDER BY avg_coverage_pct DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 20,
        "barWidth": 0.9,
        "showValue": "always",
        "colorByField": "metric"
      }
    },
    {
      "id": 10,
      "title": "Последние рейсы",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 14},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT callsign, flight_date, source, coverage_pct, total_length_m/1000 AS route_km\nFROM flight_coverage\nWHERE total_length_m > 0\nORDER BY updated_at DESC\nLIMIT 50;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "from": 0,
                "to": 0,
                "result": {"text": "N/A", "color": "gray"}
              }
            }
          ]
        }
      }
    },
    {
      "id": 8,
      "title": "Покрытие % по времени",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT hour AS time, avg_coverage_pct AS value FROM coverage_history ORDER BY hour;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        }
      }
    },
    {
      "id": 9,
      "title": "Треки по источникам по времени",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 30},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroup(track_timestamp, '1m') AS time, source, count(*) AS value\nFROM tracks\nWHERE $__timeFilter(track_timestamp) AND source IS NOT NULL\nGROUP BY time, source\nORDER BY time;"
        }
      ],
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "sortBy": "value",
          "sortDesc": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "stacking": {"mode": "normal"}
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "source"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "{{source}}"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Рейсов по источникам",
      "type": "piechart",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 38},
      "targets": [
        {
          "datasource": {"uid": "postgres-public", "type": "postgres"},
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(CASE WHEN source = 'opensky' THEN 1 ELSE 0 END) AS opensky, SUM(CASE WHEN source = 'pocketworld' THEN 1 ELSE 0 END) AS pocketworld, SUM(CASE WHEN source = 'aviaradar' THEN 1 ELSE 0 END) AS aviaradar FROM flight_coverage;"
        }
      ],
      "options": {
        "displayLabels": ["name", "percent", "value"],
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": ["value", "percent"]
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "time_period",
        "type": "custom",
        "query": "all,1year,2years,5years",
        "current": {"value": "all", "text": "All"},
        "default": "all",
        "hide": 0,
        "label": "Time Period",
        "options": [
          {"text": "All", "value": "all"},
          {"text": "1 Year", "value": "1year"},
          {"text": "2 Years", "value": "2years"},
          {"text": "5 Years", "value": "5years"}
        ]
      }
    ]
  },
  "schemaVersion": 30,
  "version": 99
}
