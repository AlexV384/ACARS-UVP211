{
  "dashboard": {
    "title": "ACARS Coverage Dashboard",
    "uid": "acars-coverage",
    "editable": false,
    "refresh": "10s",
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "All Flights",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 3,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT count(*) AS value FROM flight_coverage",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "Airlines",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 3,
          "x": 3,
          "y": 0
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT count(DISTINCT airline_code) AS value FROM airline_coverage WHERE time_period = 'all'",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "Overall Coverage %",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 3,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT avg(avg_coverage_pct) AS value FROM airline_coverage WHERE time_period = 'all'",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 30
                },
                {
                  "color": "green",
                  "value": 70
                }
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Active Flights",
        "type": "stat",
        "gridPos": {
          "h": 8,
          "w": 3,
          "x": 9,
          "y": 0
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT count(DISTINCT callsign) AS value FROM tracks WHERE track_timestamp > now() - interval '10 min' AND callsign IS NOT NULL",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          },
          "overrides": []
        }
      },
      {
        "id": 5,
        "title": "Geomap",
        "type": "geomap",
        "gridPos": {
          "h": 16,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT code AS name, ST_AsText(buffer) AS geom FROM acars_stations",
            "refId": "A"
          },
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT icao24, callsign, altitude, ST_AsText(point) AS geom FROM tracks WHERE track_timestamp > now() - interval '10 min' AND point IS NOT NULL",
            "refId": "B"
          },
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT code, city, ST_AsText(location) AS geom FROM acars_stations",
            "refId": "C"
          }
        ],
        "options": {
          "view": {
            "id": "coordinates",
            "lat": 55,
            "lon": 55,
            "zoom": 3
          },
          "controls": {
            "showZoom": true,
            "showAttribution": true
          },
          "layers": [
            {
              "id": "buffers",
              "type": "markers",
              "name": "Buffers",
              "config": {
                "data": {
                  "query": "A",
                  "format": "table",
                  "geometry": {
                    "field": "geom",
                    "format": "wkt"
                  }
                },
                "style": {
                  "fillColor": "#00BFFF",
                  "fillOpacity": 0.15,
                  "lineColor": "#00BFFF",
                  "lineWidth": 1
                }
              }
            },
            {
              "id": "tracks",
              "type": "markers",
              "name": "Tracks",
              "config": {
                "data": {
                  "query": "B",
                  "format": "table",
                  "geometry": {
                    "field": "geom",
                    "format": "wkt"
                  }
                },
                "style": {
                  "markerSize": 6,
                  "markerColor": "callsign"
                }
              }
            },
            {
              "id": "stations",
              "type": "markers",
              "name": "Stations",
              "config": {
                "data": {
                  "query": "C",
                  "format": "table",
                  "geometry": {
                    "field": "geom",
                    "format": "wkt"
                  }
                },
                "style": {
                  "markerSize": 14,
                  "markerColor": "#FF0000",
                  "symbol": "star"
                },
                "tooltip": {
                  "fields": ["code", "city"]
                }
              }
            }
          ]
        },
        "fieldConfig": {
          "defaults": {},
          "overrides": []
        }
      },
      {
        "id": 6,
        "title": "Coverage by Airline",
        "type": "bargauge",
        "gridPos": {
          "h": 16,
          "w": 6,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT airline_code, avg_coverage_pct FROM airline_coverage WHERE time_period = '$time_period' ORDER BY avg_coverage_pct DESC",
            "refId": "A"
          }
        ],
        "options": {
          "displayMode": "gradient",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "showUnfilled": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 30
                },
                {
                  "color": "green",
                  "value": 70
                }
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 7,
        "title": "Flight Count by Source",
        "type": "piechart",
        "gridPos": {
          "h": 16,
          "w": 6,
          "x": 18,
          "y": 8
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT fc.source, count(*) AS value FROM flight_coverage fc JOIN airline_coverage ac ON fc.airline_code = ac.airline_code WHERE ac.time_period = '$time_period' GROUP BY fc.source",
            "refId": "A"
          }
        ],
        "options": {
          "displayLabels": ["name", "percent"],
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          },
          "pieType": "pie",
          "reduceOptions": {
            "calcs": ["sum"],
            "fields": "",
            "values": false
          },
          "tooltip": {
            "mode": "single"
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          },
          "overrides": []
        }
      },
      {
        "id": 8,
        "title": "Coverage % over Time",
        "type": "timeseries",
        "gridPos": {
          "h": 12,
          "w": 8,
          "x": 0,
          "y": 24
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "time_series",
            "rawSql": "SELECT hour AS time, avg_coverage_pct AS value FROM coverage_history ORDER BY hour",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "calcs": ["mean", "lastNotNull"],
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "single"
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          },
          "overrides": []
        }
      },
      {
        "id": 9,
        "title": "Tracks per Source over Time",
        "type": "timeseries",
        "gridPos": {
          "h": 12,
          "w": 8,
          "x": 8,
          "y": 24
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "time_series",
            "rawSql": "SELECT $__timeGroup(track_timestamp, '1m') AS time, source, count(*) AS value FROM tracks WHERE $__timeFilter(track_timestamp) GROUP BY 1, 2 ORDER BY 1",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "calcs": ["mean", "lastNotNull"],
            "displayMode": "list",
            "placement": "bottom"
          },
          "tooltip": {
            "mode": "multi"
          },
          "stacking": {
            "mode": "normal"
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none"
          },
          "overrides": []
        }
      },
      {
        "id": 10,
        "title": "Recent Flights",
        "type": "table",
        "gridPos": {
          "h": 12,
          "w": 8,
          "x": 16,
          "y": 24
        },
        "targets": [
          {
            "datasource": {
              "uid": "postgres-public"
            },
            "format": "table",
            "rawSql": "SELECT callsign, flight_date, source, coverage_pct, total_length_m/1000 AS route_km FROM flight_coverage ORDER BY updated_at DESC LIMIT 50",
            "refId": "A"
          }
        ],
        "options": {
          "sortBy": [
            {
              "desc": true,
              "displayName": "updated_at"
            }
          ]
        },
        "fieldConfig": {
          "defaults": {},
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "route_km"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "km"
                }
              ]
            }
          ]
        }
      },
      {
        "id": 11,
        "title": "Airline Ranking",
